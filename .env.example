# Supabase project settings (Project Settings > API). Point this at the
# "stintly-staging" project, never production — see the "Which Supabase
# project" note in .claude/skills/stintly-qa-testing/SKILL.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — sensitive, server-only, never prefix with NEXT_PUBLIC_.
# Needed for the /admin area (listing all users, sending invite emails via
# the Supabase Admin API). See lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string used by Drizzle (Project Settings > Database).
# Use the session pooler connection string — the direct connection
# (db.<ref>.supabase.co) has had intermittent DNS resolution failures on
# some networks.
DATABASE_URL=

# --- iRacing Data API (see .claude/skills/stintly-iracing-data-api/SKILL.md) ---
# Leave everything below unset for local dev: the app auto-falls-back to a
# mocked iRacing API (MSW) via instrumentation.ts. To hit the real API, set
# all OAuth vars below (IRACING_USE_MOCK is then optional — real credentials
# alone are enough to disable the mock).
IRACING_USE_MOCK=
IRACING_OAUTH_CLIENT_ID=
IRACING_OAUTH_CLIENT_SECRET=
IRACING_OAUTH_REDIRECT_URI=
IRACING_OAUTH_REFRESH_TOKEN=
